SECRET_KEY=replace-with-a-generated-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,blog.s8njee.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://blog.s8njee.com
ENABLE_SSL=False

# Leave DB_* blank for local SQLite development.
DB_ENGINE=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# For Docker/Postgres production deployments, use values like:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=s8njee
# DB_USER=s8njee
# DB_PASSWORD=change-me
# DB_HOST=db
# DB_PORT=5432

# Leave these blank to store media on the local filesystem.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
REDIS_URL=redis://localhost:6379/1
